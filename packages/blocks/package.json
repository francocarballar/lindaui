  "scripts": {
    "build": "bunchee --no-dts && tsc -p tsconfig.build.json",
    "dev": "bunchee --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
